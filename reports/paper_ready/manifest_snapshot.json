{
  "benchmark": {
    "window_size": 8,
    "pause_speed_threshold": 0.03,
    "horizon_frames": 5,
    "deep": {
      "epochs": 2,
      "hidden_dim": 16,
      "learning_rate": 0.005,
      "seed": 13,
      "batch_size": 16
    }
  },
  "datasets": {
    "chico": {
      "display_name": "CHICO",
      "input_path": "reports/paper_ready/inputs/chico_model_input.jsonl",
      "splits": {
        "train": [
          "chico_s0",
          "chico_s1",
          "chico_s2"
        ],
        "test": [
          "chico_s3"
        ]
      },
      "harmonization_fields": {
        "timestamp_ms": true,
        "pose_confidence": true,
        "human_robot_distance": true,
        "shared_workspace_flag": true,
        "rework_native_flag": true,
        "task_step": true,
        "canonical_action_label": true,
        "robot_state": false
      },
      "notes": [
        "fixture-backed CHICO export from the onboarded sample"
      ]
    },
    "ha_vid": {
      "display_name": "HA-ViD",
      "input_path": "reports/paper_ready/inputs/havid_model_input.jsonl",
      "splits": {
        "train": [
          "havid_s0",
          "havid_s1",
          "havid_s2",
          "havid_s3"
        ],
        "test": [
          "havid_s4",
          "havid_s5"
        ]
      },
      "harmonization_fields": {
        "timestamp_ms": true,
        "pose_confidence": true,
        "human_robot_distance": true,
        "shared_workspace_flag": false,
        "rework_native_flag": false,
        "task_step": true,
        "canonical_action_label": false,
        "robot_state": false
      },
      "notes": [
        "deterministic domain-gap fixture used for reproducible transfer tests"
      ]
    }
  },
  "runs": [
    {
      "name": "chico_within",
      "display_name": "CHICO train/test",
      "train_datasets": [
        "chico"
      ],
      "eval_datasets": [
        "chico"
      ],
      "description": "Within-dataset benchmark on CHICO."
    },
    {
      "name": "havid_within",
      "display_name": "HA-ViD train/test",
      "train_datasets": [
        "ha_vid"
      ],
      "eval_datasets": [
        "ha_vid"
      ],
      "description": "Within-dataset benchmark on HA-ViD."
    },
    {
      "name": "chico_to_havid",
      "display_name": "CHICO -> HA-ViD",
      "train_datasets": [
        "chico"
      ],
      "eval_datasets": [
        "ha_vid"
      ],
      "description": "Cross-dataset transfer from CHICO to HA-ViD."
    },
    {
      "name": "havid_to_chico",
      "display_name": "HA-ViD -> CHICO",
      "train_datasets": [
        "ha_vid"
      ],
      "eval_datasets": [
        "chico"
      ],
      "description": "Cross-dataset transfer from HA-ViD to CHICO."
    },
    {
      "name": "merged_train_eval",
      "display_name": "Merged CHICO+HA-ViD train/eval",
      "train_datasets": [
        "chico",
        "ha_vid"
      ],
      "eval_datasets": [
        "chico",
        "ha_vid"
      ],
      "description": "Merged training and merged evaluation benchmark."
    }
  ],
  "ablations": [
    {
      "name": "feature_subset_ablation",
      "display_name": "Feature subset ablation",
      "base_run": "merged_train_eval",
      "feature_indices": [
        0,
        2,
        4,
        5,
        6
      ],
      "frame_feature_indices": [
        2,
        3,
        4,
        5,
        6,
        7
      ],
      "notes": [
        "Drops direct XY position channels and retains motion/context features."
      ]
    },
    {
      "name": "harmonization_mask_ablation",
      "display_name": "Harmonization sensitivity ablation",
      "base_run": "merged_train_eval",
      "row_overrides": {
        "distance_to_robot_workspace": 1.0,
        "confidence": 0.5
      },
      "notes": [
        "Masks harmonization-sensitive workspace and confidence channels."
      ]
    },
    {
      "name": "label_horizon_ablation",
      "display_name": "Short-horizon label ablation",
      "base_run": "merged_train_eval",
      "horizon_frames": 3,
      "notes": [
        "Measures sensitivity to a shorter near-future label horizon."
      ]
    }
  ]
}